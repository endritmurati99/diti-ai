#####################################################################
# OpenClaw environment (example)
# Copy to `openclaw/.env` (gitignored) and fill in secrets.
#####################################################################

# Choose ONE provider and set the matching key.
OPENAI_API_KEY="__REPLACE_ME__"
ANTHROPIC_API_KEY="__REPLACE_ME__"

# Telegram bot token for the OpenClaw gateway.
TELEGRAM_BOT_TOKEN="__REPLACE_ME__"

# n8n webhook secret used as:
#   Authorization: Bearer <DITI_WEBHOOK_SECRET>
DITI_WEBHOOK_SECRET="__REPLACE_ME__"

# n8n base URL (local by default)
N8N_BASE_URL="http://localhost:5678"

# Optional full webhook URL override.
# DITI_WEBHOOK_URL="http://localhost:5678/webhook/task-create"

