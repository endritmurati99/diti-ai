# ===========================
# Diti AI — Environment Variables
# ===========================
# Kopiere diese Datei nach .env und fuelle die Werte aus.
# NIEMALS .env committen!

# --- n8n ---
N8N_URL=http://localhost:5678
N8N_API_KEY=                 # Settings -> API -> API Key
N8N_ENCRYPTION_KEY=          # Einmal setzen und sicher aufbewahren!

# --- n8n Credential IDs (nach Einrichtung in n8n eintragen) ---
N8N_TELEGRAM_CREDENTIAL_ID=  # ID der Telegram Bot Credentials in n8n
N8N_GOOGLE_CREDENTIAL_ID=    # ID der Google OAuth2 Credentials in n8n

# --- Telegram ---
TELEGRAM_BOT_TOKEN=          # Von @BotFather
TELEGRAM_CHAT_ID=            # Deine Chat-ID (fuer Outbound)

# --- Notion ---
NOTION_TOKEN=                # Integration Token (Internal Integration)
NOTION_PROJECTS_DB_ID=       # Projects Database ID
NOTION_HABITS_DB_ID=         # Habits & Weekly Goals DB ID
NOTION_HEALTH_DB_ID=         # Health Weekly DB ID
NOTION_TASK_MIRROR_DB_ID=    # Task Mirror DB ID
NOTION_AUTOMATION_DB_ID=     # Automation Registry DB ID

# --- Google (OAuth2 via n8n) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth2 Tokens werden von n8n verwaltet

# --- Strava (spaeter, Phase 4) ---
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
